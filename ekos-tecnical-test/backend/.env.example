# ─── IA ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── Base de datos (Supabase) ─────────────────────────
# Obtener en: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Búsqueda web para Sales Agent (Tavily) ───────────
# Obtener en: https://tavily.com (gratis, 1000 búsquedas/mes)
TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────
APP_SECRET_KEY=genera-uno-con-openssl-rand-hex-32
APP_ENV=development
APP_PORT=8000

# ─── CORS (URL del frontend en Vercel) ────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (opcional para bonus - SendGrid) ───────────
